{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "CMAKE_FRAMEWORK_PATH",
    "NIX_*",
    "CC",
    "LD",
    "MACOSX_DEPLOYMENT_TARGET"
  ],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:run": {
      "dependsOn": ["^build"]
    },
    "test:unit:run": {
      "dependsOn": ["^build"]
    },
    "test:browser": {
      "dependsOn": ["^build"]
    },
    "test:browser:run": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "generate": {},
    "dev": {
      "dependsOn": ["^generate"],
      "cache": false,
      "persistent": true
    },
    "//#dev:cargo": {
      "cache": false,
      "persistent": true
    },
    "//#dev:wasm": {
      "cache": false,
      "persistent": true
    }
  }
}
