{
  "name": "baml-playground-v2",
  "version": "0.0.1",
  "private": true,
  "description": "BAML Playground v2 - VSCode extension and web app",
  "scripts": {
    "build:wasm": "wasm-pack build ../baml_language/crates/baml_playground_wasm --target web --out-dir ../../../typescript2/pkg-playground/wasm --release",
    "dev:wasm": "npx nodemon --watch ../baml_language --ext rs,toml --exec \"pnpm build:wasm\"",
    "dev:webview": "pnpm --filter app-vscode-webview dev",
    "dev:vscode": "pnpm --filter app-vscode-ext dev",
    "dev:promptfiddle": "pnpm --filter app-promptfiddle dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
