{
  "name": "baml-client",
  "displayName": "BamlTest - Insider - Client",
  "description": "This is the Insider Build of the Baml VS Code extension (only use it if you are also using the dev version of the CLI).",
  "packageManager": "pnpm@9.12.0",
  "version": "1.1.0",
  "publisher": "Gloo",
  "repository": "https://github.com/BoundaryML/baml",
  "homepage": "https://boundaryml.com",
  "icon": "baml-logo.png",
  "engines": {
    "vscode": "^1.63.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:baml"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "server:build": "cd ../../../../engine && cargo build --bin baml-cli && cp target/debug/baml-cli ../typescript/vscode-ext/packages/vscode/server/",
    "server:build:release": "cd ../../../../engine && cargo build --bin baml-cli --release && cp target/release/baml-cli ../typescript/vscode-ext/packages/vscode/server/",
    "server:build:windows": "cd ../../../../engine && cargo build --bin baml-cli && cp target/debug/baml-cli.exe ../typescript/vscode-ext/packages/vscode/server/",
    "server:prep-debug-download": "pnpm run server:build && ./prep-debug-download.sh",
    "vscode:prepublish": "pnpm run esbuild-base --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node ",
    "esbuild-build": "pnpm run esbuild-base --sourcemap",
    "esbuild-watch": "pnpm run esbuild-base --sourcemap --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "watch": "esbuild --bundle --watch --sourcemap --external:vscode --format=cjs --platform=node ./src/extension.ts --outfile=out/extension.js --watch",
    "build": "pnpm run client:build",
    "clean": "rimraf out",
    "client:build": "npx tsc --noEmit && pnpm run esbuild-base --sourcemap"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.750.0",
    "@baml/common": "workspace:*",
    "@smithy/types": "^4.1.0",
    "@types/semver": "^7.5.6",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "comlink": "^4.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "env-paths": "2.2.1",
    "express": "^4.21.1",
    "http-proxy": "^1.18.1",
    "http-proxy-middleware": "^3.0.3",
    "minimatch": "6.2.0",
    "node-fetch": "^3.3.2",
    "posthog-node": "^3.2.1",
    "semver": "^7.5.4",
    "tar": "^7.4.3",
    "unique-names-generator": "^4.7.1",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageclient": "7.0.0",
    "vscode-uri": "^3.0.8",
    "watcher": "1.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/glob": "8.1.0",
    "@types/http-proxy": "^1.17.14",
    "@types/mocha": "10.0.3",
    "@types/vscode": "1.63.0",
    "@vscode/test-electron": "2.3.5",
    "@vscode/vsce": "3.2.2",
    "cpx": "^1.5.0",
    "esbuild": "^0.19.4",
    "is-ci": "3.0.1",
    "ovsx": "0.8.3",
    "rimraf": "^5.0.5",
    "typescript": "5.2.2"
  },
  "preview": true
}
