{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env",
    ".env.local",
    "tsconfig.json",
    "biome.json",
    "pnpm-workspace.yaml",
    "package.json"
  ],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "GITHUB_TOKEN",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY"
  ],
  "globalPassThroughEnv": ["HOME", "PATH", "SHELL", "USER", "TERM", "TMPDIR"],
  "tasks": {
    "//#clean": {
      "cache": false,
      "outputs": []
    },
    "@gloo-ai/baml-schema-wasm-node#build": {
      "cache": true,
      "inputs": [
        "../../engine/**/*.rs",
        "../../engine/**/Cargo.toml",
        "../../engine/**/*.j2",
        "../../engine/**/*.pest",
        "scripts/**",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "@gloo-ai/baml-schema-wasm-web#build": {
      "cache": true,
      "dependsOn": ["@gloo-ai/baml-schema-wasm-node#build"],
      "inputs": [
        "../../engine/**/*.rs",
        "../../engine/**/Cargo.toml",
        "../../engine/**/*.j2",
        "../../engine/**/*.pest",
        "scripts/**",
        "package.json"
      ],
      "outputs": ["dist/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "next-env.d.ts",
        ".output/**",
        ".vercel/output/**",
        "dist/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^topo", "^build"],
      "persistent": true
    },
    "format": {
      "dependsOn": ["^topo", "^build"]
    },
    "package": {
      "dependsOn": ["^vscode:package"]
    },
    "topo": {
      "cache": false,
      "dependsOn": ["^topo"]
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json"]
    },
    "vscode:package": {
      "dependsOn": ["^build"],
      "outputs": ["baml-*.vsix"]
    }
  },
  "ui": "tui"
}
