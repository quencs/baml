{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "ui": "tui",
  "tasks": {
    "//#clean": {
      "cache": false
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "topo": {
      "dependsOn": ["^topo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json"]
    },
    "build": {
      "dependsOn": ["^topo", "^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "watch": {
      "dependsOn": ["^watch"],
      "outputs": ["dist/**"]
    },
    "@gloo-ai/baml-schema-wasm-node#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "../../engine/**/*.rs",
        "../../engine/**/*.toml",
        "../../engine/**/*.j2",
        "../../engine/**/*.pest"
      ],
      "outputs": ["dist/**"]
    },
    "@gloo-ai/baml-schema-wasm-web#build": {
      "dependsOn": ["^build", "@gloo-ai/baml-schema-wasm-node#build"],
      "inputs": [
        "../../engine/**/*.rs",
        "../../engine/**/*.toml",
        "../../engine/**/*.j2",
        "../../engine/**/*.pest"
      ],
      "outputs": ["dist/**"]
    },
    "@gloo-ai/web-panel#build": {
      "dependsOn": [
        "^build",
        "@baml/common#build",
        "@gloo-ai/baml-schema-wasm-web#build"
      ],
      "outputs": ["dist/**"]
    },
    "@baml/common#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "fiddle-frontend": {
      "dependsOn": [
        "@baml/playground-common#build",
        "@gloo-ai/baml-schema-wasm-web#build"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@baml/playground-common#build": {
      "dependsOn": ["@baml/common#build"],
      "outputs": ["dist/**"]
    },
    "@gloo-ai/baml-language-server#build": {
      "dependsOn": ["@gloo-ai/baml-schema-wasm-node#build"],
      "outputs": ["out/**"],
      "cache": false
    },
    "baml-client": {
      "dependsOn": [
        "@gloo-ai/baml-language-server#build",
        "@gloo-ai/web-panel#build",
        "@baml/common#build"
      ],
      "outputs": ["out/**"]
    },
    "lint": {},
    "baml-client#build": {
      "dependsOn": ["@gloo-ai/baml-language-server#build"],
      "outputs": ["out/**"]
    },
    "baml#vscode:package": {
      "dependsOn": ["baml-client#build"],
      "outputs": ["baml-*.vsix"]
    },
    "package": {
      "dependsOn": ["baml#vscode:package"]
    }
  }
}
