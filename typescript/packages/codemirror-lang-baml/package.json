{
  "name": "@boundaryml/codemirror-lang-baml",
  "version": "0.1.3",
  "description": "BAML language support for CodeMirror",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "echo 'No dev command in codemirror-lang-baml/package.json' && exit 0",
    "test": "mocha test/test.js",
    "build": "rollup -c",
    "prepare": "pnpm build",
    "clean": "rm -rf .turbo node_modules dist",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false && pnpm build"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/src/index.d.ts"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.18.6",
    "@codemirror/language": "6.11.1",
    "@codemirror/legacy-modes": "6.5.1",
    "@lezer/common": "1.2.3",
    "@lezer/highlight": "1.2.1",
    "@lezer/lr": "1.4.2",
    "@uiw/codemirror-theme-vscode": "4.23.13"
  },
  "devDependencies": {
    "@lezer/generator": "1.7.3",
    "@rollup/plugin-typescript": "12.1.2",
    "mocha": "11.6.0",
    "rollup": "4.43.0",
    "typescript": "5.8.3"
  },
  "license": "MIT"
}
