@top Baml { Decl* }

Decl { ClassDecl | EnumDecl | FunctionDecl | ClientDecl | RetryPolicyDecl | TemplateStringDecl | TestDecl | TypeAliasDecl | TypeBuilderDecl | LetDecl | TrailingComment | MultilineComment }

ClassDecl { "class" IdentifierDecl "{" (TrailingComment | MultilineComment | BlockAttribute | ClassField)* "}" }

ClassField {
  IdentifierDecl TypeExpr FieldAttribute*
}

TypeAliasDecl {
  "type" IdentifierDecl "=" TypeExpr
}

// TODO: Can't easily disambiguate between dynamic class and dynamic enum
// definitions. Dynamic enums are highlighted as if they were classes.
DynamicDecl { "dynamic" IdentifierDecl "{" ClassField* "}" }

TypeBuilderDecl { TypeBuilderKeyword "{" (ClassDecl | EnumDecl | DynamicDecl | TypeAliasDecl)* "}" }

RetryPolicyDecl { RetryPolicyKeyword IdentifierDecl "{" ConfigTupleValue* "}"}

TypeExpr { ComplexTypeExpr | UnionTypeExpr }
ComplexTypeExpr {
  "(" UnionTypeExpr ")" |
  SimpleTypeExpr
}
MapTypeExpr { MapIdentifier "<" ComplexTypeExpr "," ComplexTypeExpr ">"}
ListTypeExpr { ComplexTypeExpr "[]" }
OptionalTypeExpr { ComplexTypeExpr "?" }
SimpleTypeExpr { ListTypeExpr | OptionalTypeExpr | MapTypeExpr!MapOverIdentifier | IdentifierDecl | LiteralDecl }
UnionTypeExpr { TypeExpr!TypeUnion "|" TypeExpr }

@precedence {
  TypeUnion @left
  MapOverIdentifier @left
  BinaryOp @left
  MethodCall @left
  ObjectConstruct @right
}

EnumDecl { "enum" IdentifierDecl "{" (TrailingComment | MultilineComment | BlockAttribute | EnumValueDecl)* "}" }
EnumValueDecl { IdentifierDecl FieldAttribute* }

FieldAttribute {
  "@" IdentifierDecl (AttributeValue | AttributeValue2)
}

BlockAttribute {
  "@@" IdentifierDecl (AttributeValue | AttributeValue2)
}

FunctionDecl {
  ("function" | FnKeyword) IdentifierDecl (MethodTarget)? "(" FunctionArgs ")" ("->" TypeExpr)?
  "{" (FunctionTupleValue | Statement)* "}"
}

Statement { TrailingComment | MultilineComment | LetDecl | FunctionValueExpr | ForStatement | AssignmentStatement | IfStatement | WhileStatement }
FunctionArgs { (FunctionArg ",")* FunctionArg? }
FunctionArg {
  (SelfKeyword | IdentifierDecl) (":" TypeExpr)?
}
MethodTarget { "." IdentifierDecl }
FunctionValueAtom {
  LiteralDecl | PromptExpr | IdentifierDecl | ListValue | ObjectConstructor
}
FunctionValueExpr {
  FunctionValueAtom |
  "{" LetDecl* FunctionValueExpr "}" |
  IdentifierDecl "(" (FunctionValueExpr ("," FunctionValueExpr)*)? ")" |
  FunctionValueExpr!BinaryOp BinaryOperator FunctionValueExpr |
  FunctionValueExpr!MethodCall MethodCall
}

ObjectConstructor {
  IdentifierDecl!ObjectConstruct "{" (ObjectField ("," ObjectField)* ","?)? "}"
}

ObjectField {
  IdentifierDecl ":" FunctionValueExpr
}

FunctionTupleValue { (ClientKeyword | PromptKeyword) FunctionValueAtom }

ConfigValueExpr { LiteralDecl | PromptExpr | UnquotedString | ConfigListValue | ConfigMap }
ConfigTupleValue { IdentifierDecl ConfigValueExpr }

ListValue { "[" (FunctionValueExpr ("," FunctionValueExpr)*)? "]" }
ConfigListValue { "[" (IdentifierDecl ("," IdentifierDecl)*)? "]" }
ConfigMap { "{" ConfigTupleValue* "}" }

ClientDecl {
  "client<llm>" IdentifierDecl "{" (TrailingComment | MultilineComment | ConfigTupleValue)* "}"
}

TestDecl {
  "test" IdentifierDecl "{" (TrailingComment | MultilineComment | BlockAttribute | ConfigTupleValue | TypeBuilderDecl)* "}"
}

LiteralDecl { NumericLiteral | QuotedString | BooleanLiteral }

TemplateStringDecl {
  "template_string" IdentifierDecl "(" FunctionArgs ")" PromptExpr
}

LetDecl { LetKeyword IdentifierDecl "=" FunctionValueExpr ";"? }  // Semicolons optional

// New rules for advanced expression syntax
ForStatement { 
  ForKeyword "(" (ForInLoop | ForCLoop) ")" "{" Statement* "}"
}
ForInLoop { IdentifierDecl InKeyword FunctionValueExpr }
ForCLoop { CForInit? ";" CForCondition? ";" CForUpdate? }
CForInit { LetKeyword IdentifierDecl "=" FunctionValueExpr }
CForCondition { FunctionValueExpr }  
CForUpdate { IdentifierDecl "++" }

AssignmentStatement { IdentifierDecl AssignmentOperator FunctionValueExpr ";"? }
AssignmentOperator { "+=" | "-=" | "*=" | "/=" | "=" }

IfStatement { 
  IfKeyword "(" FunctionValueExpr ")" "{" Statement* "}" (ElseIfClause)* (ElseClause)?
}

ElseIfClause { ElseKeyword IfKeyword "(" FunctionValueExpr ")" "{" Statement* "}" }
ElseClause { ElseKeyword "{" Statement* "}" }

WhileStatement { 
  WhileKeyword "(" FunctionValueExpr ")" "{" Statement* "}"
}

BinaryOperator { "+" | "-" | "*" | "/" | "==" | "!=" | "<" | ">" | "<=" | ">=" | "&&" | "||" }
MethodCall { "." IdentifierDecl "(" FunctionArgs ")" }

@tokens {

  @precedence {
    BooleanLiteral, NumericLiteral, QuotedString, UnquotedString, UnquotedAttributeValue
  }
  @precedence {
    TrailingComment, ".", "/"
  }
  @precedence {
    TrailingComment, MultilineComment, MapIdentifier, TypeBuilderKeyword, ClientKeyword, PromptKeyword, LetKeyword, FnKeyword, ForKeyword, InKeyword, IfKeyword, ElseKeyword, WhileKeyword, SelfKeyword, BooleanLiteral, IdentifierDecl, UnquotedAttributeValue
  }

  LetKeyword { "let" }
  FnKeyword { "fn" }
  ForKeyword { "for" }
  InKeyword { "in" }
  IfKeyword { "if" }
  ElseKeyword { "else" }
  WhileKeyword { "while" }
  SelfKeyword { "self" }
  ClientKeyword { "client" }
  PromptKeyword { "prompt" }
  TypeBuilderKeyword { "type_builder" }
  RetryPolicyKeyword { "retry_policy" }
  MapIdentifier { "map" }
  IdentifierDecl { $[A-Za-z]$[A-Za-z0-9-_]* }

  NumericLiteral { $[0-9]+ ("." $[0-9]+)? }
  BooleanLiteral { "true" | "false" }

  QuotedString { '"' QuotedStringChar* '"' }
  UnquotedString { UnquotedStringChar+ }
  UnquotedAttributeValue { (UnquotedStringChar | ' ')+ }

  promptChar { ![] }

  // match all unicode characters except \u0022 " and \u005c \
  QuotedStringChar { $[\u{20}\u{21}\u{23}-\u{5b}\u{5d}-\u{10ffff}] | "\\" esc }
  esc  { $["\\\/bfnrt] | "u" hex hex hex hex }
  hex  { $[0-9a-fA-F] }
  whitespace { $[ \n\r\t] }

  UnquotedStringChar { ![#@{}()[\]<>,'\n\r\t/ ]}

  TrailingComment { "//" ![\n]* }
  MultilineComment { "{//"![]*"//}" }

  "{" "}" "[" "]" "(" ")" "+" "-" "*" "/" "=" "+=" "-=" "*=" "/=" "==" "!=" "<" ">" "<=" ">=" "&&" "||" "++" "."
}

@skip {
  whitespace
}

@skip {} {
  PromptExpr { '#"' PromptExprContents '"#' }
  PromptExprContents { (promptChar)* }
  JinjaExpr { "{{" (promptChar)* "}}" }
  AttributeValue { '(' (QuotedString | UnquotedAttributeValue | PromptExprNonJinja | JinjaExpr)? ')' }
  AttributeValue2 { '(' IdentifierDecl (',' JinjaExpr)? ')' }
  PromptExprNonJinja { '#"' PromptExprContents '"#'}

}

@detectDelim