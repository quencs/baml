{
  "name": "@baml/sage-interface",
  "version": "0.1.0",
  "description": "Shared types and interfaces for BAML Sage components",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "restricted"
  }
}