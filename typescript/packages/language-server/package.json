{
  "name": "@gloo-ai/baml-language-server",
  "description": "Baml Language Server",
  "displayName": "Baml Language Server",
  "packageManager": "pnpm@9.12.0",
  "version": "0.1.0",
  "author": "Gloo",
  "license": "Apache-2.0",
  "publisher": "Gloo",
  "engines": {
    "node": ">=14"
  },
  "bin": {
    "baml-language-server": "dist/src/bin.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/language-tools.git",
    "directory": "packages/language-server"
  },
  "scripts": {
    "vscode:prepublish": "node ./build.js --minify",
    "esbuild-base": "node ./build.js",
    "esbuild-build": "node ./build.js --sourcemap",
    "esbuild-watch": "node ./build.js --sourcemap --watch",
    "dev": "tsc --watch",
    "watch": "pnpm run esbuild-watch",
    "build": "pnpm typecheck && pnpm run esbuild-base",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "clean": "rm -rf .turbo node_modules dist out"
  },
  "main": "./dist/index.js",
  "typings": "dist/src/index",
  "dependencies": {
    "@gloo-ai/baml-schema-wasm-node": "workspace:*",
    "lodash": "4.17.21",
    "vscode-languageserver": "9.0.1",
    "vscode-languageserver-textdocument": "1.0.12",
    "vscode-uri": "3.1.0",
    "zod": "3.25.66"
  },
  "devDependencies": {
    "@types/lodash": "4.17.17",
    "@types/node": "24.0.3",
    "esbuild": "0.25.5",
    "esbuild-plugin-copy": "2.1.1",
    "rimraf": "6.0.1",
    "typescript": "5.8.3"
  },
  "keywords": [
    "autocomplete",
    "intellisense",
    "language",
    "prisma",
    "server",
    "formatting",
    "linting"
  ],
  "bugs": {
    "url": "https://github.com/prisma/language-tools/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"]
}
