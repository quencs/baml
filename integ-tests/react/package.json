{
  "name": "@baml/integ-tests-react",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "clean": "git clean -xdf node_modules .next .turbo",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "release": "next build",
    "build": "next build",
    "integ-tests:ci": "infisical run --env=test -- pnpm test -- --ci --silent false --testTimeout 30000 --verbose=false --reporters=jest-junit",
    "integ-tests": "infisical run --env=test -- pnpm test -- --silent false --testTimeout 30000 --bail --reporters=default --reporters=jest-html-reporter --reporters=jest-summary-reporter",
    "integ-tests:dotenv": "dotenv -e ../.env -- pnpm test -- --silent false --testTimeout 30000",
    "test": "jest --config jest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@boundaryml/baml": "workspace:*",
    "@baml/ui": "workspace:*",
    "@boundaryml/baml-nextjs-plugin": "workspace:*",
    "jotai": "2.12.2",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.483.0",
    "marked": "^15.0.7",
    "next": "15.2.3",
    "next-themes": "^0.4.6",
    "nuqs": "2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^5.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "3.24.2",
    "zsa": "0.6.0",
    "zsa-react": "0.2.3"
  },
  "devDependencies": {
    "@swc/core": "^1.11.11",
    "@swc/jest": "^0.2.36",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.11",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporter": "^4.1.0",
    "jest-junit": "^16.0.0",
    "jest-summary-reporter": "^0.0.2",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
