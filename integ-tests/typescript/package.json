{
  "name": "@baml/integ-tests-typescript",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "tsc && pnpm run build:debug",
    "integ-tests:ci": "tsc && infisical run --env=test -- vitest run --timeout 30000 --reporter=default --reporter=junit --outputFile=./junit.xml --passWithNoTests",
    "integ-tests": "tsc && infisical run --env=test -- vitest run --timeout 60000 --passWithNoTests",
    "integ-tests:dotenv": "tsc && dotenv -e ../.env -- vitest run --timeout 30000 --passWithNoTests",
    "generate": "baml-cli generate --from ../baml_src",
    "memory-test": "BAML_LOG=info infisical run --env=test -- vitest run --timeout 60000 --passWithNoTests --filter memory",
    "typecheck": "tsc --noEmit",
    "build:debug": "cd ../../engine/language_client_typescript && pnpm build:debug"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "20.19.1",
    "dotenv-cli": "7.4.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.2",
    "vite": "7.0.0",
    "vitest": "3.2.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.39.0",
    "@aws-sdk/client-sts": "3.721.0",
    "@boundaryml/baml": "workspace:*",
    "@google/generative-ai": "0.24.0",
    "dotenv": "16.4.5",
    "esbuild": "0.25.2",
    "openai": "4.87.3"
  },
  "packageManager": "pnpm@9.12.0+sha512.4abf725084d7bcbafbd728bfc7bee61f2f791f977fd87542b3579dcb23504d170d46337945e4c66485cd12d588a0c0e570ed9c477e7ccdd8507cf05f3f92eaca",
  "type": "module"
}
