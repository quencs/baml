{
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "isolatedModules": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "types/*"]
    },
    "allowImportingTsExtensions": false
  },
  "include": ["tests/**/*", "baml_client/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
