{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "lib": [
      "es2020"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "*": [
        "node_modules/*",
        "types/*"
      ]
    },
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "tests/**/*",
    "baml_client/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
