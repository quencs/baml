{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "ui": "tui",
  "tasks": {
    "//#clean": {
      "cache": false
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "topo": {
      "dependsOn": ["^topo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "inputs": ["**/*.rs", "**/*.toml", "**/*.j2", "**/*.pest"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json", "target/**"]
    },
    "build": {
      "dependsOn": ["^topo", "^build"],
      "inputs": ["**/*.rs", "**/*.toml", "**/*.j2", "**/*.pest"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "target/**"]
    },
    "release": {
      "dependsOn": ["^topo", "^release"],
      "inputs": ["**/*.rs", "**/*.toml", "**/*.j2", "**/*.pest"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "target/**"]
    },
    "baml#vscode:package": {
      "dependsOn": ["baml-client#build"],
      "outputs": ["baml-*.vsix"]
    },
    "package": {
      "dependsOn": ["baml#vscode:package"]
    }
  }
}
