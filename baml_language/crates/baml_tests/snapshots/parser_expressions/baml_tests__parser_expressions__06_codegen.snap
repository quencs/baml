function TestPrecedence() -> bool {
    load_const 2
    load_const 3
    bin_op *
    load_const 4
    bin_op +
    store_var c
    load_const 2
    load_const 3
    load_const 4
    bin_op *
    bin_op +
    load_const 10
    load_const 2
    bin_op +
    cmp_op >
    store_var b
    load_const true
    pop_jump_if_false L0
    jump L3

  L0:
    load_const false
    pop_jump_if_false L1
