function FetchDatax(user_id: string) -> Hi {
  client VertexGCP
  prompt #"
    
            give short story {{ user_id }}
            {{ ctx.output_format }}
  "#
}

function VertexGCP.resolve() -> <unknown> {
    baml.llm.build_primitive_client("VertexGCP", "vertex-ai", "user", ["user", "assistant", "system"], { "model": "gemini-2" })
}

class Hi {
  name: string
}

client VertexGCP {
  provider: vertex-ai
}
