class Point {
    x int
    y int
}

function stringArray() -> string[] {
    ["hello", "world", "test"]
}

function intArray() -> int[] {
    [1, 2, 3]
}

function floatArray() -> float[] {
    [1.0, 2.0, 3.0]
}

