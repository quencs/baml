function NestedLoops(matrix: int[][]) -> int {
    let total = 0;
    {
        let _iter = matrix;
        let _len = _iter.length();
        let _i = 0;
        while (_i < _len) {
            let row = _iter[_i];
            _i += 1;
            {
                let _iter1 = row;
                let _len1 = _iter1.length();
                let _i1 = 0;
                while (_i1 < _len1) {
                    let val = _iter1[_i1];
                    _i1 += 1;
                    if (val < 0) {
                        continue;
                    };
                    if (val > 1000) {
                        break;
                    };
                    let processed = match (val % 3) {
                        0 => val * 2,
                        1 => val + 1,
                        _ => val,
                    };
                    total += processed;
                }
            };
        }
    };
    return total;
}

