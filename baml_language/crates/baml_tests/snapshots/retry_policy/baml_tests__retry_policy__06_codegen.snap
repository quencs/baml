function MyClient.resolve() -> baml.llm.PrimitiveClient {
    load_const "MyClient"
    load_const "openai"
    load_const "system"
    load_const "system"
    load_const "user"
    load_const "assistant"
    alloc_array 3
    load_const "gpt-4"
