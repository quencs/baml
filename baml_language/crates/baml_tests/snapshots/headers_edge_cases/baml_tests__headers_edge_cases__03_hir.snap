function HeadersAroundExpressions() -> string {
    //# BeforeLet
    let x = 5;
    //## AfterLet
    //### BeforeIf
    if (x > 0) {
        //#### InsideIf
        x
    } else {
        //#### InsideElse
        0
    };
    //### AfterIf
    //## BeforeFor
    {
        let _iter = [1, 2, 3];
        let _len = _iter.length();
        let _i = 0;
        while (_i < _len) {
            let i = _iter[_i];
            _i += 1;
            //### InsideFor
            i;
        }
    };
    //## AfterFor
    //# FinalSection
    x
}

function HeadersInComplexNesting() -> string {
    //# MainFunction
    let result = {
        //## InsideBlockExpression
        let inner = if (true) {
            //### InsideIfTrue
            let deep = {
                //#### VeryDeepBlock
                "deep value"
            };
            //### BacktoIfLevel
            deep
        } else {
            //### InsideElse
            "else value"
        };
        //## BacktoBlockLevel
        inner
    };
    //# BacktoFunctionLevel
    result
}

