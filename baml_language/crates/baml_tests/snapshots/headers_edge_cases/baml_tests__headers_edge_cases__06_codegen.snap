---
source: crates/baml_tests/src/generated_tests.rs
---
function ConsecutiveHeaders() -> string {
    notify_block FirstHeader
    notify_block SecondHeader
    notify_block ThirdHeader
    notify_block SubsectionA
    notify_block SubsectionB
    notify_block SubsectionC
    load_const "multiple consecutive headers"
    return
}

function HeaderLevels() -> string {
    notify_block Level1
    notify_block Level2
    notify_block Level3
    notify_block Level4
    notify_block Level5
    notify_block Level6
    notify_block Level7-Morethan6levels
    notify_block Level8
    notify_block Level9
    load_const "deep nesting"
    return
}

function HeaderOnlyFunction() -> string {
    notify_block JustHeaders
    notify_block NoCode
    notify_block OnlyDocumentation
    notify_block PureAnnotation
    notify_block NoExpressions
    notify_block UntilTheEnd
    load_const "default"
    return
}

function HeadersAndComments() -> string {
    notify_block HeaderBeforeComment
    notify_block HeaderAfterComment
    notify_block HeaderAfterDocComment
    load_const "test"
    return
}

function HeadersAroundExpressions() -> string {
    notify_block BeforeLet
    notify_block AfterLet
    notify_block BeforeIf
    viz_enter BeforeIf
    load_const 5
    load_const 0
    cmp_op >
    pop_jump_if_false L0
    jump L1

  L0:
    notify_block InsideElse
    jump L2

  L1:
    notify_block InsideIf

  L2:
    viz_exit BeforeIf
    notify_block AfterIf
    notify_block BeforeFor
    load_const 1
    load_const 2
    load_const 3
    alloc_array 3
    store_var _iter
    load_var _iter
    call baml.Array.length
    store_var _len
    load_const 0
    store_var _i
    viz_enter BeforeFor

  L3:
    load_var _i
    load_var _len
    cmp_op <
    pop_jump_if_false L4
    jump L5

  L4:
    viz_exit BeforeFor
    notify_block AfterFor
    notify_block FinalSection
    load_const 5
    return

  L5:
    load_var _iter
    load_var _i
    load_array_element
    store_var i
    load_var _i
    load_const 1
    bin_op +
    store_var _i
    notify_block InsideFor
    jump L3
}

function HeadersInComplexNesting() -> string {
    notify_block MainFunction
    notify_block InsideBlockExpression
    viz_enter InsideBlockExpression
    load_const true
    pop_jump_if_false L0
    jump L1

  L0:
    notify_block InsideElse
    load_const "else value"
    jump L2

  L1:
    notify_block InsideIfTrue
    notify_block VeryDeepBlock
    notify_block BacktoIfLevel
    load_const "deep value"

  L2:
    viz_exit InsideBlockExpression
    notify_block BacktoBlockLevel
    store_var result
    notify_block BacktoFunctionLevel
    load_var result
    return
}

function HeadersWithSpecialChars() -> string {
    notify_block Header-With-Dashes
    notify_block Header_With_Underscores
    notify_block Header.With.Dots
    notify_block HeaderWithSlashes
    notify_block Header\With\Backslashes
    notify_block Header|With|Pipes
    load_const "special chars"
    return
}

function HeadersWithWhitespace() -> string {
    notify_block ExtraSpacesBeforeTitle
    notify_block MixedTabsAndSpaces
    notify_block AllTabs
    notify_block TrailingSpaces
    notify_block MultipleSpacesBetweenWords
    load_const "whitespace test"
    return
}

function UnicodeHeaders() -> string {
    notify_block 你好世界
    notify_block Émojis🎉🎊
    notify_block Special«Characters»™
    load_const "test"
    return
}

function VeryLongHeaderTitle() -> string {
    notify_block ThisIsAnExtremelyLongHeaderTitleThatGoesOnAndOnAndOnAndContainsManyWordsToTestHowTheParserHandlesVeryLongHeaderTitlesThatMightSpanMultipleLinesInSomeEditorsButShouldStillBeParsedAsASingleHeader
    notify_block AnotherLongTitleWithSpecialCharacters!@$%^&*()_+-=[]{}|;':",.<>?AndNumbers1234567890
    load_const "long headers"
    return
}
