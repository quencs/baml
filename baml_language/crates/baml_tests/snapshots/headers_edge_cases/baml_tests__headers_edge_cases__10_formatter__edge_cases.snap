function HeadersAroundExpressions() -> string {
    //# Before Let
    let x = 5;
    //## After Let
    //### Before If
    if (x > 0) {
        //#### Inside If
        x
    } else {
        //#### Inside Else
        0
    }
    //### After If
    //## Before For
    for (let i in [1, 2, 3]) {
        //### Inside For
        i
    }
    //## After For
    //# Final Section
    x
}

