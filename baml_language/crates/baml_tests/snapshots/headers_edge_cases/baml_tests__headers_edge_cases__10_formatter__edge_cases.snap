function HeadersInComplexNesting() -> string {
    //# Main Function

    let result = {
        //## Inside Block Expression

        let inner = if (true) {
            //### Inside If True

            let deep = {
                //#### Very Deep Block
                "deep value"
            };
            //### Back to If Level
            deep
        } else {
            //### Inside Else
            "else value"
        };
        //## Back to Block Level
        inner
    };
    //# Back to Function Level
    result
}

function HeadersWithSpecialChars() -> string {
