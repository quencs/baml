function ReadMultipleFiles() -> string {
    load_const "file1.txt"
    dispatch_future baml.fs.open
    await
    store_var f1
    load_const "file2.txt"
    dispatch_future baml.fs.open
    await
    store_var f2
    load_var f1
    dispatch_future baml.fs.File.read
    await
    store_var content1
    load_var f2
    dispatch_future baml.fs.File.read
    await
    store_var content2
    load_var content1
    load_var content2
    bin_op +
    return
}

function RunCommand() -> string {
    load_const "echo hello"
    dispatch_future baml.sys.shell
    await
    return
}

