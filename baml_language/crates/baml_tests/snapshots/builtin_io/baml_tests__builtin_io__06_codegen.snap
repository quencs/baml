function ChainCommands() -> string {
    load_const "pwd"
    dispatch_future baml.sys.shell
    await
    store_var result1
    load_const "whoami"
    dispatch_future baml.sys.shell
    await
    store_var result2
    load_var result1
    load_const " - "
    bin_op +
    load_var result2
    bin_op +
    return
}

function ConnectAndRead() -> string {
    load_const "127.0.0.1:8080"
    dispatch_future baml.net.connect
    await
    dispatch_future baml.net.Socket.read
    await
    return
}

function ConnectAndReadInline() -> string {
    load_const "localhost:3000"
    dispatch_future baml.net.connect
    await
    dispatch_future baml.net.Socket.read
    await
    return
}

function ConnectReadAndClose() -> string {
    load_const "127.0.0.1:8080"
    dispatch_future baml.net.connect
    await
    store_var sock
    load_var sock
    dispatch_future baml.net.Socket.read
    await
    store_var data
    load_var sock
    dispatch_future baml.net.Socket.close
    await
    pop 1
    load_var data
    return
}

function MultipleConnections() -> string {
    load_const "server1:80"
    dispatch_future baml.net.connect
    await
    store_var s1
    load_const "server2:80"
    dispatch_future baml.net.connect
    await
    store_var s2
    load_var s1
    dispatch_future baml.net.Socket.read
    await
    store_var data1
    load_var s2
    dispatch_future baml.net.Socket.read
    await
    store_var data2
    load_var data1
    load_var data2
    bin_op +
    return
}

function ReadAndClose() -> string {
    load_const "example.txt"
    dispatch_future baml.fs.open
    await
    store_var f
    load_var f
    dispatch_future baml.fs.File.read
    await
    store_var content
    load_var f
    dispatch_future baml.fs.File.close
    await
    pop 1
    load_var content
    return
}

function ReadFile() -> string {
    load_const "example.txt"
    dispatch_future baml.fs.open
    await
    dispatch_future baml.fs.File.read
    await
    return
