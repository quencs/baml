function BodyTorture() -> int {
    load_const null
    store_var x

  L0:
    load_var x
    load_const 1
    bin_op +
    store_var x
    load_const null
    pop_jump_if_false L1
    jump L2

  L1:
    load_const null
    return

  L2:
    load_var x
    load_const 1
    bin_op +
    store_var x
    jump L0
}

function ComplexType() -> map<string, map<string, map<string, int[]?>>> {
    load_var _0
    return
}

function DeepExpression() -> int {
    load_const 1
    load_const 2
    bin_op +
    load_const 3
    bin_op *
    load_const 4
    bin_op -
    load_const 5
    bin_op /
    load_const 6
    bin_op +
    load_const 7
    bin_op *
    load_const 8
    bin_op -
    load_const 9
    bin_op /
    load_const 10
    bin_op +
    return
}

