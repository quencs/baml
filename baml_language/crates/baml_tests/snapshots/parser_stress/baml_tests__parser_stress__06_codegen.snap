function BodyTorture() -> int {
    load_const null
    store_var x

  L0:
    load_var x
    load_const 1
    bin_op +
    store_var x
    load_const null
    pop_jump_if_false L1
    jump L2

  L1:
    load_const null
    return

  L2:
    load_var x
    load_const 1
    bin_op +
    store_var x
    jump L0
}

