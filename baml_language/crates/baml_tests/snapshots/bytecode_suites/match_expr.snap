---
source: crates/baml_tests/src/bytecode_snapshot.rs
---
match_catch_all_underscore:
    baml: |

        function main() -> int {
            match (42) {
                _ => 100
            }
        }

    bytecode: |
        function main() -> int {
            load_const 100
            return
        }

    result: BexExternalValue::Int(100)

match_catch_all_named_binding:
    baml: |

        function main() -> int {
            match (42) {
                x => x + 1
            }
        }

    bytecode: |
        function main() -> int {
            load_const 42
            load_const 1
            bin_op +
            return
        }

    result: BexExternalValue::Int(43)

match_literal_int_with_fallback:
    baml: |

        function main() -> int {
            match (1) {
                1 => 100,
            }
        }

    bytecode: |
        function main() -> int {
            load_const 1
            pop 1
            load_const 100
            return
        }

    result: BexExternalValue::Int(100)

match_literal_bool_exhaustive:
    baml: |

        function main() -> string {
            match (true) {
                true => "yes",
            }
        }

    bytecode: |
        function main() -> string {
            load_const "yes"
            return
        }

    result: BexExternalValue::String("yes")

match_typed_pattern_single_class:
    baml: |

        class Success {
            data string
        }

        function main() -> string {
            let result = Success { data: "hello" };
            match (result) {
                s: Success => s.data,
            }
        }

    bytecode: |
        function main() -> string {
            alloc_instance Success
            copy 0
            load_const "hello"
            store_field .data
            store_var result
            load_var result
            load_field .data
            return
        }

    result: BexExternalValue::String("hello")

match_typed_pattern_two_classes:
    baml: |

        class Success {
            data string
        }

        class Failure {
            reason string
        }

        function main() -> string {
            let result = Success { data: "ok" };
            match (result) {
                s: Success => s.data,
            }
        }

    bytecode: |
        function main() -> string {
            alloc_instance Success
            copy 0
            load_const "ok"
            store_field .data
            store_var result
            load_var result
            load_field .data
            return
        }

    result: BexExternalValue::String("ok")

match_union_literal_two_values:
    baml: |

        function main() -> string {
            match (200) {
                200 | 201 => "success",
            }
        }

    bytecode: |
        function main() -> string {
            load_const 200
            copy 0
            load_const 200
            cmp_op ==
            pop_jump_if_false L0
            pop 1

          L0:
            pop 1
            load_const "success"
            return
        }

    result: |
        ERROR: panic during execution: attempt to subtract with overflow
        RUST_ERR_DEBUG: Panic("attempt to subtract with overflow")

match_in_arithmetic:
    baml: |

        function main() -> int {
            1 + match (2) {
                2 => 20,
            }
        }

    bytecode: |
        function main() -> int {
            load_const 2
            pop 1
            load_const 1
            load_const 20
            bin_op +
            return
        }

    result: BexExternalValue::Int(21)

match_nested:
    baml: |

        function main() -> int {
            match (1) {
                1 => match (2) {
                    2 => 12,
                },
            }
        }

    bytecode: |
        function main() -> int {
            load_const 1
            pop 1
            load_const 2
            pop 1
            load_const 12
            return
        }

    result: BexExternalValue::Int(12)

match_jump_table_dense_four_arms:
    baml: |

        function classify(x int) -> int {
            match (x) {
                0 => 100,
                1 => 101,
                2 => 102,
                3 => 103,
                _ => 999
            }
        }

    entry: classify

    args:
      x: 0

    bytecode: |
        function classify(x: int) -> int {
            load_var x
            jump_table [L4, L3, L2, L1], default L0

          L0:
            load_const 999
            jump L5

          L1:
            load_const 103
            jump L5

          L2:
            load_const 102
            jump L5

          L3:
            load_const 101
            jump L5

          L4:
            load_const 100

          L5:
            return
        }

    result: BexExternalValue::Int(100)

match_binary_search_sparse_four_arms:
    baml: |

        function classify(x int) -> int {
            match (x) {
                0 => 100,
                30 => 130,
                60 => 160,
                99 => 199,
                _ => 999
            }
        }

    entry: classify

    args:
      x: 0

    bytecode: |
        function classify(x: int) -> int {
            load_var x
            copy 0
            load_const 60
            cmp_op ==
            pop_jump_if_false L0
            pop 1
            jump L5

          L0:
            copy 0
            load_const 60
            cmp_op <
            pop_jump_if_false L2
            copy 0
            load_const 0
            cmp_op ==
            pop_jump_if_false L1
            pop 1
            jump L7

          L1:
            copy 0
            load_const 30
            cmp_op ==
            pop_jump_if_false L2
            pop 1
            jump L6

          L2:
            copy 0
            load_const 99
            cmp_op ==
            pop_jump_if_false L3
            pop 1
            jump L4

          L3:
            pop 1
            load_const 999
            jump L8

          L4:
            load_const 199
            jump L8

          L5:
            load_const 160
            jump L8

          L6:
            load_const 130
            jump L8

          L7:
            load_const 100

          L8:
            return
        }

    result: BexExternalValue::Int(100)

