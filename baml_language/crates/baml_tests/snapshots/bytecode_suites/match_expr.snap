match_guarded_int_literal:
    baml: |

        function classify(x int, flag bool) -> string {
            match (x) {
                1 if flag => "one with flag",
                1 => "one",
                _ => "other"
            }
        }

    entry: classify

    args:
      x: 0
      flag: false

    bytecode: |
        function classify(x: int, flag: bool) -> string {
            load_var x
            load_const 1
            cmp_op ==
            pop_jump_if_false L0
            load_var flag
            pop_jump_if_false L0
            jump L3

          L0:
            load_var x
            load_const 1
            cmp_op ==
            pop_jump_if_false L1
            jump L2

          L1:
            load_const "other"
            jump L4

          L2:
            load_const "one"
            jump L4

          L3:
            load_const "one with flag"

          L4:
            return
        }

    result: BexExternalValue::String("other")

match_mixed_literal_typed_guard:
    baml: |

        function classify(x int, flag bool) -> string {
            match (x) {
                0 => "zero",
                1 if flag => "one with flag",
                n: int => "other int"
            }
