return_with_stack:
    baml: |

        function with_stack(x: int) -> int {
          let a = 1;

          // NOTE: currently there's no empty returns.

          if (a == 0) { return 0; }

          {
             let b = 1;
             if (a != b) {
                return 0;
             }
          }

          {
             let c = 2;
             let b = 3;
             while (b != c) {
                if (true) {
                   return 0;
                }
             }
          }

           7
        }

    bytecode: |
