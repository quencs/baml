            jump L4

          L1:
            load_const 3
            load_const 2
            cmp_op !=
            pop_jump_if_false L2
            jump L3

          L2:
            load_const 7
            return

          L3:
            load_const true
            pop_jump_if_false L1
            load_const 0
            return

          L4:
            load_const 0
            return

          L5:
            load_const 0
            return
        }

