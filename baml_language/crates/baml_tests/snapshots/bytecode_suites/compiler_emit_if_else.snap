if_else_literal_true:
    baml: |

        function main() -> int {
            if (true) { 1 } else { 2 }
        }

    bytecode: |
        function main() -> int {
            load_const true
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            return
        }

    result: BexExternalValue::Int(1)

if_else_literal_false:
    baml: |

        function main() -> int {
            if (false) { 1 } else { 2 }
        }

    bytecode: |
        function main() -> int {
            load_const false
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            return
        }

    result: BexExternalValue::Int(2)

