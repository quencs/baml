        RUST_ERR_DEBUG: Panic("index out of bounds: the len is 1 but the index is 1")

virtual_multiple_defs_preserve_side_effects_codegen:
    baml: |

        function fail() -> int {
            assert(false);
            1
        }

        function main() -> int {
            let x = fail();
            x = 2;
            x
        }

    bytecode: |
        function fail() -> int {
            load_const false
            assert
            load_const 1
            return
        }

        function main() -> int {
            call fail
            store_var x
            load_const 2
            store_var x
            load_var x
            return
        }

    result: |
        ERROR: execution failed for case 'virtual_multiple_defs_preserve_side_effects_codegen': engine call_function failed for 'main': VM error: assertion failed: assertion failed: assertion failed
        RUST_ERR_DEBUG: Err(execution failed for case 'virtual_multiple_defs_preserve_side_effects_codegen'

        Caused by:
            0: engine call_function failed for 'main'
            1: VM error: assertion failed
            2: assertion failed
            3: assertion failed)
