---
source: crates/baml_tests/src/bytecode_snapshot.rs
---
virtual_cross_block_soundness_codegen:
    baml: |

        function main(c: bool) -> int {
            let a = 1;
            let b = a;
            if (c) {
                a = 2;
            }
            b
        }

    bytecode: |
        function main(c: bool) -> int {
            load_const 1
            store_var a
            load_var a
            store_var b
            load_var c
            pop_jump_if_false L0
            load_const 2
            store_var a

          L0:
            load_var b
            return
        }

    result: |
        ERROR: panic during execution: index out of bounds: the len is 2 but the index is 2
        RUST_ERR_DEBUG: Panic("index out of bounds: the len is 2 but the index is 2")

virtual_cross_block_param_mutation_soundness_codegen:
    baml: |

        function main(c: bool, p: int) -> int {
            let x = p;
            if (c) {
                p = 2;
            }
            x
        }

    bytecode: |
        function main(c: bool, p: int) -> int {
            load_var p
            store_var x
            load_var c
            pop_jump_if_false L0
            load_const 2
            store_var p

          L0:
            load_var x
            return
        }

    result: |
        ERROR: panic during execution: index out of bounds: the len is 1 but the index is 1
        RUST_ERR_DEBUG: Panic("index out of bounds: the len is 1 but the index is 1")

