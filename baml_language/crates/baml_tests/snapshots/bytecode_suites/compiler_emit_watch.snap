viz_header_before_if_emits_viz_enter_exit:
    baml: |

        function header_before_if() -> int {
            //# MyHeader
            if (true) {
                1
            } else {
                2
            }
        }

    bytecode: |
        function header_before_if() -> int {
            notify_block MyHeader
            viz_enter MyHeader
            load_const true
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            viz_exit MyHeader
            return
        }

    result: |
