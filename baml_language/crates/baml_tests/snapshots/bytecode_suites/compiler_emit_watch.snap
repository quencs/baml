viz_header_before_while_emits_viz_enter_exit:
    baml: |

        function header_before_while() -> int {
            let x = 0;
            //# LoopHeader
            while (x < 5) {
                x = x + 1;
            }
            x
        }

    bytecode: |
        function header_before_while() -> int {
            load_const 0
            store_var x
            notify_block LoopHeader
            viz_enter LoopHeader

          L0:
            load_var x
            load_const 5
            cmp_op <
            pop_jump_if_false L1
            jump L2

          L1:
            viz_exit LoopHeader
            load_var x
            return

          L2:
            load_var x
            load_const 1
            bin_op +
            store_var x
            jump L0
        }

    result: |
        ERROR: execution failed for case 'viz_header_before_while_emits_viz_enter_exit': engine call_function failed for 'main': Function not found: main
