watch_primitive:
    baml: |

        function primitive() -> int {
            watch let value = 0;

            value = 1;

            value
        }

    bytecode: |
        function primitive() -> int {
            load_const 0
            store_var value
            load_const "value"
            load_const null
            watch value
            load_const 1
            store_var value
            load_var value
            unwatch value
            return
        }

