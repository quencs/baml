create_and_access:
    baml: |

        function create_map() -> map<string, string> {
            { "hello": "world" }
        }

        function use_map() -> string {
            let map = create_map();
            map["hello"]
        }

    bytecode: |
        function create_map() -> map<string, string> {
            load_const "world"
            load_const "hello"
            alloc_map 1
            return
        }

        function use_map() -> string {
            call create_map
            load_const "hello"
            load_map_element
            return
        }

