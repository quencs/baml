        class Point {
            x int
            y int
        }

        function main() -> Point {
            let p = Point { x: 1, y: 2 };
            p
        }

    bytecode: |
        function main() -> Point {
            alloc_instance Point
            copy 0
            load_const 1
            store_field .x
            copy 0
            load_const 2
            store_field .y
            return
        }

    result: 'BexExternalValue::Instance { class_name: "Point", fields: {"x": Int(1), "y": Int(2)} }'

