while_loop_with_conditional_break:
    baml: |

        function count_down(n: int) -> int {
            let result = 0;
            while (true) {
                result = result + n;
                n = n - 1;
                if (n == 0) {
                    break;
                }
            }
            result
        }

    entry: count_down

