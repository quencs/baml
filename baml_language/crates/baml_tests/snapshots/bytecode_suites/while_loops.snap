while_loop_gcd:
    baml: |

        function gcd(a: int, b: int) -> int {
            while (a != b) {
                if (a > b) {
                    a = a - b;
                } else {
                    b = b - a;
                }
            }

            a
        }

    entry: gcd

    args:
      a: 21
      b: 15

    bytecode: |
        function gcd(a: int, b: int) -> int {
          L0:
            load_var a
            load_var b
            cmp_op !=
            pop_jump_if_false L1
            jump L2

          L1:
            load_var a
            return

          L2:
            load_var a
            load_var b
            cmp_op >
            pop_jump_if_false L3
            jump L4

          L3:
            load_var b
            load_var a
            bin_op -
            store_var b
            jump L0

          L4:
            load_var a
            load_var b
            bin_op -
            store_var a
            jump L0
        }

    result: BexExternalValue::Int(3)

