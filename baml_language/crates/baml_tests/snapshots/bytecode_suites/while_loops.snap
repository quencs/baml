continue_factorial:
    baml: |

        function factorial(limit: int) -> int {
            let result = 1;

            let should_continue = true;
            while (should_continue) {
                result = result * limit;
                limit = limit - 1;

                if (limit != 0) {
                    continue;
                } else {
                    should_continue = false;
                }
            }

            result
        }

    entry: factorial

    args:
      limit: 5

    bytecode: |
        function factorial(limit: int) -> int {
            load_const 1
            store_var result
            load_const true
            store_var should_continue

          L0:
