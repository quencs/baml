viz_if_without_header_no_viz_events:
    baml: |

        function if_no_header() -> int {
            if (true) {
                1
            } else {
                2
            }
        }

    entry: if_no_header

    bytecode: |
        function if_no_header() -> int {
            load_const true
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            return
        }

    result: BexExternalValue::Int(1)
