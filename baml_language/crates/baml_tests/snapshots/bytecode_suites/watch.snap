---
source: crates/baml_tests/src/bytecode_snapshot.rs
---
watch_primitive:
    baml: |

        function primitive() -> int {
            watch let value = 0;

            value = 1;

            value
        }

    entry: primitive

    bytecode: |
        function primitive() -> int {
            load_const 0
            store_var value
            load_const "value"
            load_const null
            watch value
            load_const 1
            store_var value
            load_var value
            unwatch value
            return
        }

    notifications: [
        "Variables([LocalVar(StackKind(0))])",
    ]

    result: Complete(Int(1))

viz_header_before_if_emits_viz_enter_exit:
    baml: |

        function header_before_if() -> int {
            //# MyHeader
            if (true) {
                1
            } else {
                2
            }
        }

    entry: header_before_if

    bytecode: |
        function header_before_if() -> int {
            notify_block MyHeader
            viz_enter MyHeader
            load_const true
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            viz_exit MyHeader
            return
        }

    notifications: [
        "Block(BlockNotification { function_name: \"header_before_if\", block_name: \"MyHeader\", level: 1, block_type: Statement, is_enter: true })",
        "Viz { function_name: \"header_before_if\", event: VizExecEvent { delta: Enter, node_id: 0, node_type: BranchGroup, label: \"MyHeader\", header_level: None } }",
        "Viz { function_name: \"header_before_if\", event: VizExecEvent { delta: Exit, node_id: 0, node_type: BranchGroup, label: \"MyHeader\", header_level: None } }",
    ]

    result: Complete(Int(1))

viz_header_before_while_emits_viz_enter_exit:
    baml: |

        function header_before_while() -> int {
            let x = 0;
            //# LoopHeader
            while (x < 5) {
                x = x + 1;
            }
            x
        }

    entry: header_before_while

    bytecode: |
        function header_before_while() -> int {
            load_const 0
            store_var x
            notify_block LoopHeader
            viz_enter LoopHeader

          L0:
            load_var x
            load_const 5
            cmp_op <
            pop_jump_if_false L1
            jump L2

          L1:
            viz_exit LoopHeader
            load_var x
            return

          L2:
            load_var x
            load_const 1
            bin_op +
            store_var x
            jump L0
        }

    notifications: [
        "Block(BlockNotification { function_name: \"header_before_while\", block_name: \"LoopHeader\", level: 1, block_type: Statement, is_enter: true })",
        "Viz { function_name: \"header_before_while\", event: VizExecEvent { delta: Enter, node_id: 0, node_type: Loop, label: \"LoopHeader\", header_level: None } }",
        "Viz { function_name: \"header_before_while\", event: VizExecEvent { delta: Exit, node_id: 0, node_type: Loop, label: \"LoopHeader\", header_level: None } }",
    ]

    result: Complete(Int(5))

viz_standalone_header_no_viz_enter_exit:
    baml: |

        function standalone_header() -> int {
            //# JustAHeader
            let x = 5;
            x
        }

    entry: standalone_header

    bytecode: |
        function standalone_header() -> int {
            notify_block JustAHeader
            load_const 5
            return
        }

    notifications: [
        "Block(BlockNotification { function_name: \"standalone_header\", block_name: \"JustAHeader\", level: 1, block_type: Statement, is_enter: true })",
    ]

    result: Complete(Int(5))

viz_multiple_headers_only_one_before_if:
    baml: |

        function multiple_headers() -> int {
            //# FirstHeader
            let x = 1;
            //# SecondHeader
            if (x > 0) {
                2
            } else {
                3
            }
        }

    entry: multiple_headers

    bytecode: |
        function multiple_headers() -> int {
            notify_block FirstHeader
            notify_block SecondHeader
            viz_enter SecondHeader
            load_const 1
            load_const 0
            cmp_op >
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 3
            jump L2

          L1:
            load_const 2

          L2:
            viz_exit SecondHeader
            return
        }

    notifications: [
        "Block(BlockNotification { function_name: \"multiple_headers\", block_name: \"FirstHeader\", level: 1, block_type: Statement, is_enter: true })",
        "Block(BlockNotification { function_name: \"multiple_headers\", block_name: \"SecondHeader\", level: 1, block_type: Statement, is_enter: true })",
        "Viz { function_name: \"multiple_headers\", event: VizExecEvent { delta: Enter, node_id: 0, node_type: BranchGroup, label: \"SecondHeader\", header_level: None } }",
        "Viz { function_name: \"multiple_headers\", event: VizExecEvent { delta: Exit, node_id: 0, node_type: BranchGroup, label: \"SecondHeader\", header_level: None } }",
    ]

    result: Complete(Int(2))

viz_if_without_header_no_viz:
    baml: |

        function if_no_header() -> int {
            if (true) {
                1
            } else {
                2
            }
        }

    entry: if_no_header

    bytecode: |
        function if_no_header() -> int {
            load_const true
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            return
        }

    result: BexExternalValue::Int(1)

