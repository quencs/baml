        function nested_alias() -> Point {
            alloc_instance Point
            copy 0
            load_const 0
            store_field .x
            copy 0
            load_const 0
            store_field .y
            store_var point
            load_const "point"
            load_const null
            watch point
            load_const true
            pop_jump_if_false L0
            load_var point
            load_const 1
            store_field .x

          L0:
            load_var point
            unwatch point
            return
        }

    notifications: [
        "Variables([LocalVar(StackKind(0))])",
    ]

    result: 'Complete(Instance(Point { x: Int(1), y: Int(0) }))'

notify_when_nested_object_is_modified_after_addtion:
    baml: |

        class Value {
            value int
        }

        class Point {
            x Value
            y Value
        }

        class Vec2D {
            p Point
            q Point
        }

        function nested_object_added() -> Vec2D {
            watch let vec = Vec2D {
                p: Point { x: Value { value: 0 }, y: Value { value: 0 } },
                q: Point { x: Value { value: 0 }, y: Value { value: 0 } },
            };

            let p = Point { x: Value { value: 1 }, y: Value { value: 1 } };

            vec.p = p; // Notify here.
            p.x.value = 2; // Notify here too.

            vec
        }

    entry: nested_object_added

    bytecode: |
        function nested_object_added() -> Vec2D {
            alloc_instance Vec2D
            copy 0
            alloc_instance Point
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .x
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .y
            store_field .p
            copy 0
            alloc_instance Point
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .x
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .y
            store_field .q
            store_var vec
            load_const "vec"
            load_const null
            watch vec
            alloc_instance Point
            copy 0
            alloc_instance Value
            copy 0
            load_const 1
            store_field .value
            store_field .x
            copy 0
            alloc_instance Value
            copy 0
            load_const 1
            store_field .value
            store_field .y
            store_var p
            load_var vec
            load_var p
            store_field .p
            load_var p
            load_field .x
            load_const 2
            store_field .value
            load_var vec
            unwatch vec
            return
        }

    notifications: [
        "Variables([LocalVar(StackKind(0))])",
        "Variables([LocalVar(StackKind(0))])",
    ]

    result: 'Complete(Instance(Vec2D { p: Instance(Point { x: Instance(Value { value: Int(2) }), y: Instance(Value { value: Int(1) }) }), q: Instance(Point { x: Instance(Value { value: Int(0) }), y: Instance(Value { value: Int(0) }) }) }))'

dont_notify_when_nested_object_is_modified_after_removal:
    baml: |

        class Value {
            value int
        }

        class Point {
            x Value
            y Value
        }

        class Vec2D {
            p Point
            q Point
        }

        function nested_object_removed() -> Vec2D {
            watch let vec = Vec2D {
                p: Point { x: Value { value: 0 }, y: Value { value: 0 } },
                q: Point { x: Value { value: 0 }, y: Value { value: 0 } },
            };

            let p = vec.p;

            vec.p = Point { x: Value { value: 1 }, y: Value { value: 1 } }; // Notify once here

            p.x.value = 2; // No notify here

            vec
        }

    entry: nested_object_removed

    bytecode: |
        function nested_object_removed() -> Vec2D {
            alloc_instance Vec2D
            copy 0
            alloc_instance Point
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .x
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .y
            store_field .p
            copy 0
            alloc_instance Point
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .x
            copy 0
            alloc_instance Value
            copy 0
            load_const 0
            store_field .value
            store_field .y
            store_field .q
            store_var vec
            load_const "vec"
            load_const null
            watch vec
            load_var vec
            load_field .p
            store_var p
            load_var vec
            alloc_instance Point
            copy 0
            alloc_instance Value
            copy 0
            load_const 1
            store_field .value
            store_field .x
            copy 0
            alloc_instance Value
            copy 0
            load_const 1
            store_field .value
            store_field .y
            store_field .p
            load_var p
            load_field .x
            load_const 2
            store_field .value
            load_var vec
            unwatch vec
            return
        }

    notifications: [
        "Variables([LocalVar(StackKind(0))])",
    ]

    result: 'Complete(Instance(Vec2D { p: Instance(Point { x: Instance(Value { value: Int(1) }), y: Instance(Value { value: Int(1) }) }), q: Instance(Point { x: Instance(Value { value: Int(0) }), y: Instance(Value { value: Int(0) }) }) }))'

cyclic_graph:
    baml: |

        class Vertex {
            edges Vertex[]
            value int
        }

        function cycle() -> int {
            let v1 = Vertex { value: 1, edges: [] };
            watch let v2 = Vertex { value: 2, edges: [] };
            let v3 = Vertex { value: 3, edges: [] };
            watch let v4 = Vertex { value: 4, edges: [] };

            // NO EMIT (neither v2 nor v4 have changed)
            v1.edges = [v2];

            // EMIT v2
            v2.edges = [v3];

            // EMIT v2
            v3.edges = [v4];

            // EMIT [v2, v4]
            v4.edges = [v1];

            // EMIT [v2, v4]
            v2.value = 20;

            // EMIT [v2, v4]
            v1.value = 10;

            // EMIT [v2, v4]
            v3.value = 30;

            0
        }

    entry: cycle

    bytecode: |
        function cycle() -> int {
            alloc_instance Vertex
            copy 0
            load_const 1
            store_field .edges
            copy 0
            alloc_array 0
            store_field .value
            store_var v1
            alloc_instance Vertex
            copy 0
            load_const 2
            store_field .edges
            copy 0
            alloc_array 0
            store_field .value
            store_var v2
            load_const "v2"
            load_const null
            watch v2
            alloc_instance Vertex
            copy 0
            load_const 3
            store_field .edges
            copy 0
            alloc_array 0
            store_field .value
            store_var v3
            alloc_instance Vertex
            copy 0
            load_const 4
            store_field .edges
            copy 0
            alloc_array 0
            store_field .value
            store_var v4
            load_const "v4"
            load_const null
            watch v4
            load_var v1
            load_var v2
            alloc_array 1
            store_field .edges
            load_var v2
            load_var v3
            alloc_array 1
            store_field .edges
            load_var v3
            load_var v4
            alloc_array 1
            store_field .edges
            load_var v4
            load_var v1
            alloc_array 1
            store_field .edges
            load_var v2
            load_const 20
            store_field .value
            load_var v1
            load_const 10
            store_field .value
            load_var v3
            load_const 30
            store_field .value
            unwatch v4
            unwatch v2
            load_const 0
            return
        }

    notifications: [
        "Variables([LocalVar(StackKind(1))])",
        "Variables([LocalVar(StackKind(1))])",
        "Variables([LocalVar(StackKind(1)), LocalVar(StackKind(3))])",
        "Variables([LocalVar(StackKind(1)), LocalVar(StackKind(3))])",
        "Variables([LocalVar(StackKind(1)), LocalVar(StackKind(3))])",
        "Variables([LocalVar(StackKind(1)), LocalVar(StackKind(3))])",
    ]

    result: Complete(Int(0))

run_user_filter:
    baml: |

        function greater_than_five(value: int) -> bool {
            value > 5
        }

        function primitive() -> int {
            watch let value = 0;
            value.$watch.options(baml.WatchOptions { when: greater_than_five });

            value = 1; // No notify
            value = 6; // Notify

            value
        }

    entry: primitive

    bytecode: |
        function greater_than_five(value: int) -> bool {
            load_var value
            load_const 5
            cmp_op >
            return
        }

        function primitive() -> int {
            load_const 0
            store_var value
            load_const "value"
            load_const null
            watch value
            load_const "value"
            load_global <fn greater_than_five>
            watch value
            load_const 1
            store_var value
            load_const 6
            store_var value
            load_var value
            unwatch value
            return
        }

    notifications: [
        "Variables([LocalVar(StackKind(0))])",
    ]

    result: Complete(Int(6))

