manual_notify:
    baml: |

        function primitive() -> int {
            watch let value = 0;
            value.$watch.options(baml.WatchOptions { when: "manual" });

            value = 1; // No notify
            value = 2; // No notify
            value = 3; // No notify

            value.$watch.notify(); // Notify

            value
        }

    entry: primitive

    bytecode: |
        function primitive() -> int {
            load_const 0
            store_var value
            load_const "value"
            load_const null
            watch value
            load_const "value"
            load_const "manual"
            watch value
            load_const 1
            store_var value
            load_const 2
            store_var value
            load_const 3
            store_var value
            notify value
            load_var value
            unwatch value
            return
        }

    notifications: [
        "Variables([LocalVar(StackKind(0))])",
    ]

    result: Complete(Int(3))

