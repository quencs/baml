---
source: crates/baml_tests/src/bytecode_snapshot.rs
---
exec_if_branch:
    baml: |

        function run_if(b: bool) -> int {
            if (b) { 1 } else { 2 }
        }

        function main() -> int {
            let a = run_if(true);
            a
        }

    bytecode: |
        function main() -> int {
            load_const true
            call run_if
            return
        }

        function run_if(b: bool) -> int {
            load_var b
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            return
        }

    result: BexExternalValue::Int(1)

exec_else_branch:
    baml: |

        function run_if(b: bool) -> int {
            if (b) { 1 } else { 2 }
        }

        function main() -> int {
            let a = run_if(false);
            a
        }

    bytecode: |
        function main() -> int {
            load_const false
            call run_if
            return
        }

        function run_if(b: bool) -> int {
            load_var b
            pop_jump_if_false L0
            jump L1

          L0:
            load_const 2
            jump L2

          L1:
            load_const 1

          L2:
            return
        }

    result: BexExternalValue::Int(2)

exec_else_if_branch:
    baml: |

        function run_if(a: bool, b: bool) -> int {
            if (a) {
                1
            } else if (b) {
                2
            } else {
                3
            }
        }

        function main() -> int {
            let a = run_if(false, true);
            a
        }

    bytecode: |
        function main() -> int {
            load_const false
            load_const true
            call run_if
            return
        }

        function run_if(a: bool, b: bool) -> int {
            load_var a
            pop_jump_if_false L0
            jump L3

          L0:
            load_var b
            pop_jump_if_false L1
            jump L2

          L1:
            load_const 3
            jump L4

          L2:
            load_const 2
            jump L4

          L3:
            load_const 1

          L4:
            return
        }

    result: BexExternalValue::Int(2)
