---
source: crates/baml_tests/src/bytecode_snapshot.rs
---
basic_add:
    baml: |

        function main() -> int {
            1 + 2
        }

    bytecode: |
        function main() -> int {
            load_const 1
            load_const 2
            bin_op +
            return
        }

    result: BexExternalValue::Int(3)

