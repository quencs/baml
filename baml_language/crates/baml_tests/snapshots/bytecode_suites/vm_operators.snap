negative_int_in_let:
    baml: |

        function main() -> int {
            let x = -5;
            x
        }

    bytecode: |
        function main() -> int {
            load_const 5
            unary_op -
            return
        }

    result: BexExternalValue::Int(-5)

negative_int_arithmetic:
    baml: |

        function main() -> int {
            -5 + 3
        }

    bytecode: |
        function main() -> int {
            load_const 5
            unary_op -
            load_const 3
            bin_op +
            return
        }

    result: BexExternalValue::Int(-2)

negative_int_comparison:
    baml: |

        function main() -> bool {
            -5 < 0
        }

    bytecode: |
        function main() -> bool {
            load_const 5
            unary_op -
            load_const 0
            cmp_op <
            return
        }

    result: BexExternalValue::Bool(true)

