basic_and:
    baml: |

        function main() -> bool {
            true && false
        }

    bytecode: |
        function main() -> bool {
            load_const true
            pop_jump_if_false L0
            jump L1

          L0:
            load_const false
            jump L2

          L1:
            load_const false

          L2:
            return
        }

    result: BexExternalValue::Bool(false)

basic_or:
    baml: |

        function main() -> bool {
            true || false
        }

    bytecode: |
        function main() -> bool {
            load_const true
            pop_jump_if_false L0
            jump L1

          L0:
            load_const false
            jump L2

          L1:
            load_const true

          L2:
            return
        }

    result: BexExternalValue::Bool(true)

