match_jump_table_dense_four_arms:
    baml: |

        function classify(x int) -> int {
            match (x) {
                0 => 100,
                1 => 101,
                2 => 102,
                3 => 103,
                _ => 999
            }
        }

    bytecode: |
        function classify(x: int) -> int {
            load_var x
            jump_table [L4, L3, L2, L1], default L0

          L0:
            load_const 999
            jump L5

          L1:
            load_const 103
            jump L5

          L2:
            load_const 102
            jump L5

          L3:
            load_const 101
            jump L5

          L4:
            load_const 100

          L5:
            return
        }

