---
source: crates/baml_tests/src/bytecode_snapshot.rs
---
match_catch_all_underscore:
    baml: |

        function main() -> int {
            match (42) {
                _ => 100
            }
        }

    bytecode: |
        function main() -> int {
            load_const 100
            return
        }

    result: BexExternalValue::Int(100)

match_catch_all_named_binding:
    baml: |

        function main() -> int {
            match (42) {
                x => x + 1
            }
        }

    bytecode: |
        function main() -> int {
            load_const 42
            load_const 1
            bin_op +
            return
        }

    result: BexExternalValue::Int(43)

match_literal_int_with_fallback:
    baml: |

        function main() -> int {
            match (1) {
                1 => 100,
            }
        }

    bytecode: |
        function main() -> int {
            load_const 1
            pop 1
            load_const 100
            return
        }

    result: BexExternalValue::Int(100)

match_literal_bool_exhaustive:
    baml: |

        function main() -> string {
            match (true) {
                true => "yes",
            }
        }

    bytecode: |
        function main() -> string {
            load_const "yes"
            return
        }

    result: BexExternalValue::String("yes")

match_typed_pattern_single_class:
    baml: |

        class Success {
            data string
        }

        function main() -> string {
            let result = Success { data: "hello" };
            match (result) {
                s: Success => s.data,
            }
        }

    bytecode: |
        function main() -> string {
            alloc_instance Success
            copy 0
            load_const "hello"
            store_field .data
            store_var result
            load_var result
            load_field .data
            return
        }

    result: BexExternalValue::String("hello")

match_typed_pattern_two_classes:
    baml: |

        class Success {
            data string
        }

        class Failure {
            reason string
        }

        function main() -> string {
            let result = Success { data: "ok" };
            match (result) {
                s: Success => s.data,
            }
        }

    bytecode: |
        function main() -> string {
            alloc_instance Success
            copy 0
            load_const "ok"
            store_field .data
            store_var result
            load_var result
            load_field .data
            return
        }

    result: BexExternalValue::String("ok")

match_union_literal_two_values:
    baml: |

        function main() -> string {
            match (200) {
                200 | 201 => "success",
            }
        }

    bytecode: |
        function main() -> string {
            load_const 200
            copy 0
            load_const 200
            cmp_op ==
            pop_jump_if_false L0
            pop 1

          L0:
            pop 1
            load_const "success"
            return
        }

    result: |
        ERROR: panic during execution: attempt to subtract with overflow
        RUST_ERR_DEBUG: Panic("attempt to subtract with overflow")

match_in_arithmetic:
    baml: |

        function main() -> int {
            1 + match (2) {
                2 => 20,
            }
        }

    bytecode: |
        function main() -> int {
            load_const 2
            pop 1
            load_const 1
            load_const 20
            bin_op +
            return
        }

    result: BexExternalValue::Int(21)

match_nested:
