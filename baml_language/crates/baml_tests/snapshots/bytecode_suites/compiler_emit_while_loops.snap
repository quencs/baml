while_loop_gcd:
    baml: |

        function gcd(a: int, b: int) -> int {
            while (a != b) {
                if (a > b) {
                    a = a - b;
                } else {
                    b = b - a;
                }
            }

            a
        }

    bytecode: |
        function gcd(a: int, b: int) -> int {
          L0:
            load_var a
            load_var b
            cmp_op !=
            pop_jump_if_false L1
            jump L2

          L1:
            load_var a
            return

          L2:
            load_var a
            load_var b
            cmp_op >
            pop_jump_if_false L3
            jump L4

          L3:
            load_var b
            load_var a
            bin_op -
            store_var b
            jump L0

          L4:
            load_var a
            load_var b
            bin_op -
            store_var a
            jump L0
        }

    result: |
        ERROR: execution failed for case 'while_loop_gcd': engine call_function failed for 'main': Function not found: main
        RUST_ERR_DEBUG: Err(execution failed for case 'while_loop_gcd'

        Caused by:
            0: engine call_function failed for 'main'
            1: Function not found: main)

while_loop_with_ending_if:
    baml: |

        function main() -> int {
            let a = 1;

            while (a < 5) {
                a += 1;

                if (a == 2) {
                    break;
                }
            }

            a
        }

    bytecode: |
