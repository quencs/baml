break_factorial:
    baml: |

        function factorial(limit: int) -> int {
            let result = 1;

            while (true) {
                if (limit == 0) {
                    break;
                }
                result = result * limit;
                limit = limit - 1;
            }

            result
        }

    bytecode: |
        function factorial(limit: int) -> int {
            load_const 1
            store_var result

          L0:
            load_const true
            pop_jump_if_false L2
            load_var limit
            load_const 0
            cmp_op ==
            pop_jump_if_false L1
            jump L2

          L1:
            load_var result
            load_var limit
            bin_op *
            store_var result
            load_var limit
            load_const 1
            bin_op -
            store_var limit
            jump L0

          L2:
            load_var result
            return
        }

