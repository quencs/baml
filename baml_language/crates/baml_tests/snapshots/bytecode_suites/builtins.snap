builtin_method_call:
    baml: |

        function main() -> int {
            let arr = [1, 2, 3];
            arr.length()
        }

    bytecode: |
        function main() -> int {
            load_const 1
            load_const 2
            load_const 3
            alloc_array 3
            call baml.Array.length
            return
        }

    result: BexExternalValue::Int(3)

