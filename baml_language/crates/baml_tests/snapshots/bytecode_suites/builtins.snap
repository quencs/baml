fetch_as_with_request_param:
    baml: |

        class DummyJsonTodo {
            id int
            todo string
            completed bool
            user_id int
        }

        function main() -> DummyJsonTodo {
            baml.fetch_as<DummyJsonTodo>(baml.HttpRequest {
                method: baml.HttpMethod.Post,
                url: "https://dummyjson.com/todos/add",
                json: {
                    "todo": "Buy milk",
                    "completed": false,
                    "userId": 5
