for_loop_sum:
    baml: |

        function sum(xs: int[]) -> int {
            let result = 0;

            for (let x in xs) {
                result += x;
            }

            result
        }

    entry: sum

    args:
      xs: []

    bytecode: |
        function sum(xs: int[]) -> int {
            load_const 0
            store_var result
            load_var xs
            call baml.Array.length
            store_var _len
            load_const 0
            store_var _i

          L0:
            load_var _i
            load_var _len
            cmp_op <
            pop_jump_if_false L1
            jump L2

          L1:
            load_var result
            return

          L2:
            load_var xs
            load_var _i
            load_array_element
            store_var x
            load_var _i
            load_const 1
            bin_op +
            store_var _i
            load_var result
            load_var x
            bin_op +
            store_var result
            jump L0
        }

    result: BexExternalValue::Int(0)

