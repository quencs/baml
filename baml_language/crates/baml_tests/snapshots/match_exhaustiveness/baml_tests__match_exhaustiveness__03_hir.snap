class Success {
  data: string
}

class Pending {
  eta: int
}

class Failure {
  reason: string
}

enum Status {
  Active
  Inactive
  Pending
}

type Result = Success | Failure

type OkOrCreated = OkCode | 201

type MaybeOk = 200?

type SuccessCode = 200 | 201 | 204

type AlwaysFalse = false

