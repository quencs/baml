type MixedLiterals = 200 | "success" | true

type MaybeResult = Result?

type CustomBool = true | false

type Role = "user" | "assistant" | "system"

type FullResult = Success | Failure | Pending

type SuccessOr200 = Success | 200

type HttpCreated = 201

type HttpOk = 200

type DoubleMaybe = MaybeResult?

type AlwaysTrue = true
