function LLMAnalyze(text: string) -> Analysis {
    load_const "LLMAnalyze"
    load_var text
    load_const "text"
    alloc_map 1
    call baml.llm.call_llm_function
    return
}

function ProcessAnalysis(analysis: Analysis) -> string {
    load_var analysis
    load_field .score
    store_var score
    load_var score
    load_const 0.8
    cmp_op >
    pop_jump_if_false L0
    jump L5

  L0:
    load_var score
    load_const 0.5
    cmp_op >
    pop_jump_if_false L1
    jump L4

  L1:
    load_var score
    load_const 0.2
    cmp_op >
    pop_jump_if_false L2
    jump L3

  L2:
    load_const "Negative: "
    load_var analysis
    load_field .sentiment
    bin_op +
    return

  L3:
    load_const "Neutral: "
    load_var analysis
    load_field .sentiment
    bin_op +
    return

  L4:
    load_const "Positive: "
    load_var analysis
    load_field .sentiment
    bin_op +
    return

  L5:
    load_const "Very positive: "
    load_var analysis
    load_field .sentiment
    bin_op +
    return
}

function ProcessData(data: JsonData) -> string {
    load_var data
    load_field .field1
    load_var data
    load_field .field2
    bin_op +
    load_const 100
    cmp_op >
    pop_jump_if_false L0
    jump L1

  L0:
    load_const "low"
    return

  L1:
    load_const "high"
    return
}

function SimpleCalc(a: int, b: int) -> int {
    load_var a
    load_var b
    load_const 2
    bin_op *
    bin_op +
    return
}
