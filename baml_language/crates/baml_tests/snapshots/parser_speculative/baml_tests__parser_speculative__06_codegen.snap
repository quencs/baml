---
source: crates/baml_tests/src/generated_tests.rs
---
function Ambiguous(input: string) -> string {
    load_const "Ambiguous"
    load_var input
    load_const "input"
    alloc_map 1
    call baml.llm.call_llm_function
    return
}

function AnotherLLM(input: string) -> string {
    load_const "AnotherLLM"
    load_var input
    load_const "input"
    alloc_map 1
    call baml.llm.call_llm_function
    return
}

