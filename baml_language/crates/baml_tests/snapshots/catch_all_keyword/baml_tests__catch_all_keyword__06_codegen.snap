function CatchAllTyped(x: int) -> string {
    push_unwind L0, slot 2
    load_var x
    call MayFailIntOrString
    pop_unwind
    jump L5

  L0:
    load_var _2
    store_var e
    load_var _2
    type_tag
    load_const 1
    cmp_op ==
    pop_jump_if_false L1
    jump L4

  L1:
    load_var _2
    type_tag
    load_const 0
    cmp_op ==
    pop_jump_if_false L2
    jump L3

  L2:
    load_var _2
    throw

  L3:
    load_const "caught int"
    jump L5

  L4:
    load_const "caught string"

  L5:
    return
}

