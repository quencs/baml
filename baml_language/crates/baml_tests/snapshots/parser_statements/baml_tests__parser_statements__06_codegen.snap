function ConditionalLogic(age: int) -> string {
    load_var age
    load_const 18
    cmp_op <
    pop_jump_if_false L0
    jump L3

  L0:
    load_var age
    load_const 65
    cmp_op <
    pop_jump_if_false L1
    jump L2

  L1:
    load_const "senior"
    return

  L2:
    load_const "adult"
    return

  L3:
    load_const "minor"
    return
}

