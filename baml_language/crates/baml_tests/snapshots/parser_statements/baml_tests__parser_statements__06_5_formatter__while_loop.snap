=== ORIGINAL ===
function simple_while_loop() -> int {
  let i = 0;
  while (i < 10) {
    i = i + 1;
  }
  return i;
}

function nested_while_loop() -> int {
  let i = 0;
  while (i < 10) {
    let j = 0;
    while (j < 10) {
      j = j + 1;
    }
  }
  return i;
}

