---
source: crates/baml_tests/src/generated_tests.rs
---
function Bar() -> int {
    let x = Foo(1);
    x
}

function Foo(x: int) -> int {
    x + 1
}

function GreetBaz(n: string) -> string {
    let baz = Baz { name: n };
    baz.Greeting()
}

class Baz {
    name: string

    function Greeting(self) -> string {
        "Hello, " + self.name + "!"
    }
}

// Simple param in if statement.
function param_in_if_statement(b: bool) -> int {
    if (b) {
        1
    } else {
        2
    }
}
