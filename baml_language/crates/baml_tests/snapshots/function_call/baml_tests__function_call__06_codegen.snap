function Bar() -> int {
    load_const 1
    call Foo
    return
}

function Baz.Greeting(self: Baz) -> string {
    load_const "Hello, "
    load_var self
    load_field .name
    bin_op +
    load_const "!"
    bin_op +
    return
}

function Foo(x: int) -> int {
    load_var x
    load_const 1
    bin_op +
    return
}

function GreetBaz(n: string) -> string {
    alloc_instance Baz
    copy 0
    load_var n
    store_field .name
    call Baz.Greeting
    return
}

function array_length() -> int {
    load_const 1
    load_const 2
    load_const 3
    alloc_array 3
    call baml.Array.length
    return
}

function param_in_if_statement(b: bool) -> int {
    load_var b
    pop_jump_if_false L0
    jump L1

  L0:
    load_const 2
    jump L2

  L1:
    load_const 1

  L2:
    return
}

function stream_Baz.Greeting(self: stream_Baz) -> string {
    load_const "Hello, "
    load_var self
    load_field .name
    bin_op +
    load_const "!"
    bin_op +
    return
}
