function CommentAfterArrow() -> string {
    load_const "CommentAfterArrow"
    alloc_map 0
    call baml.llm.call_llm_function
    return
}

function FunctionWithComments(a: string, b: int) -> string {
    load_const "FunctionWithComments"
    load_var a
    load_var b
    load_const "a"
    load_const "b"
    alloc_map 2
    call baml.llm.call_llm_function
    return
}

function TestClient.resolve() -> baml.llm.PrimitiveClient {
    load_const "TestClient"
    load_const "baml-openai-chat"
    load_const "user"
    load_const "user"
    load_const "assistant"
    load_const "system"
    alloc_array 3
    alloc_map 0
    dispatch_future baml.llm.build_primitive_client
    await
    return
}
