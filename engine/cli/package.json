{
  "name": "@baml/cli",
  "version": "0.1.0",
  "private": true,
  "files": ["../target/debug/baml-cli", "../target/release/baml-cli"],
  "scripts": {
    "dev": "cargo build",
    "clean": "cargo clean && git clean -fdf .turbo node_modules target",
    "typecheck": "cargo build",
    "build": "cargo build",
    "release": "cargo build --release",
    "format": "cargo fmt",
    "format:check": "cargo fmt --check",
    "format:fix": "cargo fmt",
    "lint": "cargo clippy -- -D warnings",
    "test": "cargo test",
    "test:watch": "cargo watch -x test"
  },
  "dependencies": {
    "@baml/language-server": "workspace:*"
  }
}
