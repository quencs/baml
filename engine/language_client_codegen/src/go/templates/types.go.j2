type Checked[T any] baml.Checked[T]


{% for class in classes %}
{%- if let Some(docstring) = class.docstring %}
{{ docstring }}
{%- endif %}
type {{ class.name }} struct {
{% for field in class.fields %}
	{%- if let Some(docstring) = field.docstring -%}
	{{ docstring }}
	{%- endif %}
	{{ field.name|exported_name }} {{ field.go_type.name }} `json:"{{ field.name }}"`
{% endfor %}
{% if class.dynamic %}
	DynamicProperties map[string]any `json:"__baml_dynamic_properties__"`
{% endif %}
}

func (c *{{ class.name }}) Decode(holder cffi.CFFIValueClass, typeMap baml.TypeMap) {
	if string(holder.Name()) != "{{ class.name }}" {
		panic(fmt.Sprintf("expected {{ class.name }}, got %s", string(holder.Name())))
	}


	{% if class.fields|length > 0 %}
	for i := range holder.FieldsLength() {
		var field cffi.CFFIMapEntry
		if holder.Fields(&field, i) {
			key := string(field.Key())
			valueHolder := field.Value(nil)
			switch key {
				{% for field in class.fields %}
				case "{{ field.name }}":
					c.{{ field.name|exported_name }} = {{ crate::go::generate_types::render_value_coercion("valueHolder", field.go_type) }}
				{% endfor %}
			}
		}
	}
{% endif %}

{% if class.dynamic %}
	for i := range holder.DynamicFieldsLength() {
		var field cffi.CFFIMapEntry
		if holder.DynamicFields(&field, i) {
			key := string(field.Key())
			valueHolder := field.Value(nil)
			c.DynamicProperties[key] = baml.Decode(valueHolder, typeMap)
		}
	}
{% endif %}
}

func (c *{{ class.name }}) BamlEncode() ([]byte, error) {
valueMap := map[string]any{}

{% for field in class.fields %}
{% let destination_index = format!("\"{}\"", crate::go::generate_types::to_exported_name(field.name.as_ref())) %}
{% let source_variable_name = format!("c.{}", crate::go::generate_types::to_exported_name(field.name.as_ref())) %}
{{ crate::go::generate_types::render_value_encode("valueMap", destination_index, source_variable_name, field.go_type) }}
{% endfor %}

encodedMap := map[string]any{
"class_name": "{{ class.name }}",
"values": valueMap,
}

return json.Marshal(encodedMap)
}

{% endfor %}

