func (c *{{ class.name }}) BamlDecode(decodedMap map[string]any) {
	{% if class.fields|length > 0 %}
	for name, value := range decodedMap {
		switch name {
		{% for (name, type, _) in class.fields %}
		case "{{ name|exported_name }}":
			coercedValue := value.({{ type|type_without_pointer }})
			c.{{ name|exported_name }} = {% if type|is_pointer %}&{% endif %}coercedValue
		{% endfor %}
		}
	}
	{% endif %}
}

