                "OUTPUT_TOKEN_COST": Constant(
                    Number(0.00006),
                ),
            },
            returns: {
                "total_cost": OutputExpression(
                    "(response.body.usageMetadata.promptTokenCount - response.body.usageMetadata.cachedTokenCount) * INPUT_TOKEN_COST + response.body.usageMetadata.candidatesTokenCount * OUTPUT_TOKEN_COST\n",
                ),
            },
        },
    ),
    Some(
        MatchedFunction {
            constants: {
                "DEFAULT_INPUT_COST": Constant(
