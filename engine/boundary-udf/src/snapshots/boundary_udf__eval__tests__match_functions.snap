            constants: {
                "DEFAULT_INPUT_COST": Constant(
                    Number(0.001),
                ),
                "DEFAULT_OUTPUT_COST": Constant(
                    Number(0.002),
                ),
                "INPUT_TOKEN_COST": Constant(
                    Number(0.00002),
