{
  "name": "@baml/rpc",
  "version": "0.1.0",
  "description": "BAML RPC bindings for Next.js applications",
  "type": "module",
  "exports": {
    "./*": "./bindings/*.ts"
  },
  "scripts": {
    "dev": "cargo build && tsc --watch",
    "build": "cargo build && tsc",
    "release": "cargo build --release && tsc",
    "typecheck": "cargo test && tsc --noEmit --emitDeclarationOnly false",
    "clean": "git clean -fdf .turbo node_modules target",
    "format": "cargo fmt",
    "format:check": "cargo fmt --check",
    "format:fix": "cargo fmt",
    "lint": "cargo clippy -- -D warnings",
    "test": "cargo test",
    "test:watch": "cargo watch -x test"
  },
  "devDependencies": {
    "typescript": "5.8.3"
  }
}
