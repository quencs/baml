[package]
name = "{{ package_name }}"
version = "{{ version }}"
edition = "2021"
description = "Generated BAML client for Rust"
authors = ["BAML Generator"]
license = "MIT"

# Automatically generated by BAML - do not edit manually
# Generated at: {{ generation_timestamp }}
# BAML version: {{ baml_version }}

[dependencies]
# Core BAML runtime
baml-client-rust = "{{ baml_client_version }}"

# Async runtime
tokio = { version = "1.0", features = ["full"] }
futures = "0.3"

# Serialization
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"

# Error handling
anyhow = "1.0"
thiserror = "1.0"

[dev-dependencies]
tokio-test = "0.4"

[features]
default = []

# Optional features
tracing = ["baml-client-rust/tracing"]
metrics = ["baml-client-rust/metrics"]

[lib]
name = "{{ lib_name }}"
path = "src/lib.rs"

[[bin]]
name = "{{ package_name }}-cli"
path = "src/bin/cli.rs"
required-features = ["cli"]

[package.metadata.baml]
version = "{{ baml_version }}"
generated_at = "{{ generation_timestamp }}"
generator = "rust"