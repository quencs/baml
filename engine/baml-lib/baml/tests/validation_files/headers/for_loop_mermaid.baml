# Loop Processing
fn ForLoopWithHeaders() -> int {
    let items = [1, 2, 3, 4, 5];
    let result = 0;
    
    ## Main Loop
    for (item in items) {
        ### Item Processing
        let processed = item * 2;
        
        ### Accumulation
        result = result + processed

        processed
    }
    
    ## Final Result
    result
}


